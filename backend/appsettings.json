{
  "ConnectionStrings": {
    "Default": "Data Source=Data/vni_automation.db"
  },
  "Jwt": {
    "Issuer": "VNI.Automation",
    "Audience": "VNI.Automation.Client",
    "SecretKey": "",
    "AccessTokenMinutes": 60
  },
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": ""
  },
  "FileStorage": {
    "RootPath": "Storage/Files",
    "PublicBaseUrl": "/api/mediaasset",
    "MaxUploadBytes": 8388608,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/webp"]
  },
  "Scheduler": {
    "Enabled": false,
    "IntervalSeconds": 30,
    "BatchSize": 10
  },
  "DevSeed": {
    "Enabled": false,
    "AdminEmail": "admin@vni.local",
    "AdminPassword": "",
    "DefaultSocialChannelId": "00000000-0000-0000-0000-000000000001",
    "DefaultPageContextId": "00000000-0000-0000-0000-000000000002",
    "DefaultCategoryId": "00000000-0000-0000-0000-000000000003"
  },
  "AiProviders": {
    "DefaultProvider": "9router",
    "Providers": {
      "9router": {
        "Api": "openai-completions",
        "BaseUrl": "http://127.0.0.1:20128/v1",
        "ApiKey": "",
        "ChatCompletionsPath": "/chat/completions",
        "DefaultTextModel": "cx/gpt-5.5",
        "MaxTokens": 8192,
        "Temperature": 0.7,
        "ContextWindow": 200000
      },
      "openai": {
        "Api": "openai-completions",
        "BaseUrl": "https://api.openai.com/v1",
        "ApiKey": "",
        "ChatCompletionsPath": "/chat/completions",
        "DefaultTextModel": "gpt-4.1-mini",
        "MaxTokens": 8192,
        "Temperature": 0.7,
        "ContextWindow": 128000
      }
    }
  },
  "MetaOAuth": {
    "AppId": "",
    "AppSecret": "",
    "GraphBaseUrl": "https://graph.facebook.com",
    "GraphVersion": "v20.0",
    "RedirectUri": "http://localhost:5068/api/meta/callback",
    "FrontendSuccessUri": "http://localhost:5173/platforms?metaConnected=success",
    "FrontendErrorUri": "http://localhost:5173/platforms?metaConnected=error",
    "Scopes": [
      "public_profile",
      "pages_show_list",
      "pages_read_engagement",
      "pages_manage_posts"
    ]
  },
  "SocialPublish": {
    "DefaultProvider": "facebook",
    "UseRealFacebook": false,
    "Facebook": {
      "GraphBaseUrl": "https://graph.facebook.com",
      "GraphVersion": "v20.0",
      "TimeoutSeconds": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
