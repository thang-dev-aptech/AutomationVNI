# =============================================================================
# Template biến môi trường cho deploy. File này KHÔNG chứa giá trị thật và
# được commit lên git.
#
# Cách dùng:
#   cp .env.example .env.production   # rồi điền giá trị thật vào bản copy
#   docker compose --env-file .env.production up -d
#
# .NET đọc "A__B__C" thành cấu hình "A:B:C". Hai gạch dưới, không phải một.
# =============================================================================

ASPNETCORE_ENVIRONMENT=Production
PORT=8080

# --- Bảo mật -----------------------------------------------------------------
# Sinh khoá mới: openssl rand -base64 48
Jwt__SecretKey=
Seed__AdminEmail=
Seed__AdminPassword=

# --- Database ----------------------------------------------------------------
# Trỏ vào volume để dữ liệu sống qua các lần redeploy (xem docker-compose.yml).
ConnectionStrings__Default=Data Source=/app/Data/vni_automation.db

# --- Meta / Facebook ---------------------------------------------------------
# App Dashboard → App settings → Basic (cặp trên cùng)
MetaOAuth__AppId=
MetaOAuth__AppSecret=

# --- Threads -----------------------------------------------------------------
# CÙNG trang đó nhưng kéo xuống phần "Threads App ID" / "Threads App secret".
# Đây là cặp KHÁC với cặp Meta ở trên — dùng nhầm sẽ báo lỗi 4476002.
ThreadsOAuth__AppId=
ThreadsOAuth__AppSecret=

# --- URL callback ------------------------------------------------------------
# Phải khớp tuyệt đối với URI đã đăng ký trong Meta App Dashboard.
# Threads KHÔNG chấp nhận localhost, bắt buộc HTTPS domain public.
MetaOAuth__RedirectUri=https://<domain>/api/meta/callback
MetaOAuth__FrontendSuccessUri=https://<domain>/platforms?metaConnected=success
MetaOAuth__FrontendErrorUri=https://<domain>/platforms?metaConnected=error

ThreadsOAuth__RedirectUri=https://<domain>/api/threads/callback
ThreadsOAuth__FrontendSuccessUri=https://<domain>/platforms?threadsConnected=success
ThreadsOAuth__FrontendErrorUri=https://<domain>/platforms?threadsConnected=error

# --- AI ----------------------------------------------------------------------
# Provider mặc định "9router" trỏ vào 127.0.0.1 — chỉ chạy được trên máy dev,
# trong container sẽ fail. Production dùng openai.
AiProviders__DefaultProvider=openai
AiProviders__Providers__openai__ApiKey=

AiImageProviders__Providers__gemini__ApiKey=

# --- Bật tính năng nền -------------------------------------------------------
# appsettings.json để false hết cho dev; production phải bật.
Scheduler__Enabled=true
GenerationWorker__Enabled=true
SocialPublish__UseRealFacebook=true
